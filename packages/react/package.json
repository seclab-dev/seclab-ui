    "react-dom": "^19.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seclab-dev/seclab-ui.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2"
  }
