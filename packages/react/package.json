{
  "name": "@seclab-dev/react",
  "version": "0.1.0-alpha.5",
  "description": "SecLab React 19 UI Component Library",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/style.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
