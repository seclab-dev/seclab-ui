{
  "name": "seclab-ui",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "build": "pnpm --filter './packages/*' --workspace-concurrency=1 build",
    "dev": "pnpm -C playground dev",
    "dev:react": "pnpm -C playground-react dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "playground:favicon": "node scripts/build-playground-favicon.mjs",
    "type-check": "pnpm --filter './packages/*' --workspace-concurrency=1 type-check",
    "pack:check": "node scripts/check-packages.mjs",
    "test:consumer": "pnpm -C playground build && pnpm -C playground-react build",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "check": "pnpm format:check && pnpm type-check && pnpm build && pnpm test:unit && pnpm test:consumer && pnpm pack:check"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "semver": "^7.8.5",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  }
}
